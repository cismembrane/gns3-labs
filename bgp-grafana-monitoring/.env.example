# Copy this file to .env and edit with your chosen values.
# cp .env.example .env

# Grafana admin credentials. If .env does not exist, compose falls back
# to admin/admin as defined in docker-compose.yml.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# SNMPv3 credentials for snmp_exporter. Must match the values configured
# on the routers (see group_vars/routers.yml, which uses ansible-vault).
SNMP_USERNAME=monitor
SNMP_AUTH_PASSWORD=replace-me
SNMP_PRIV_PASSWORD=replace-me
